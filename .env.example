# ──────────────────────────────────────────────────────────
# Evidence Vault — Environment Variables
# Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────────────────

# Application environment (development | staging | production)
NODE_ENV=development

# Server port for the vault API
PORT=3000

# PostgreSQL connection string for vault metadata
DATABASE_URL=postgresql://localhost:5432/evidence_vault

# AWS region for S3 storage and KMS
AWS_REGION=us-east-1

# AWS credentials (use IAM roles in production)
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret

# S3 bucket for encrypted evidence blobs
S3_BUCKET=evidence-vault-dev

# S3 server-side encryption algorithm (AES256 | aws:kms)
S3_ENCRYPTION=AES256

# AWS KMS key ID for envelope encryption (if using aws:kms)
KMS_KEY_ID=your-kms-key-id

# Master encryption key for client-side key wrapping (256-bit, base64)
MASTER_KEY=your-256-bit-master-key

# Maximum file upload size in megabytes
MAX_FILE_SIZE_MB=100

# Default expiry for sharing links in hours
SHARE_LINK_EXPIRY_HOURS=48

# Default evidence retention period in days (7 years = 2555 days)
RETENTION_DEFAULT_DAYS=2555
